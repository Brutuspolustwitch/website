# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Twitch API (for clips, stream status, etc.) ─────────────────────
# Get these from https://dev.twitch.tv/console/apps
# 1. Go to https://dev.twitch.tv/console
# 2. Click "Register Your Application"
# 3. Name: Arena Gladiator (or anything)
# 4. OAuth Redirect URL: http://localhost:3000/api/auth/twitch/callback
# 5. Category: Website Integration
# 6. Copy the Client ID and generate a Client Secret
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# ── Twitch Channel ───────────────────────────────────────────────────
NEXT_PUBLIC_TWITCH_CHANNEL=brutuspolus

# ── Site URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://arena-gladiator.gg

# ── StreamElements ───────────────────────────────────────────────────
SE_JWT_TOKEN=your-streamelements-jwt
SE_CHANNEL_ID=your-streamelements-channel-id
